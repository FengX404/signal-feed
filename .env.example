# ============================================================
# 环境变量配置（可选）
# ============================================================
# 环境变量优先级高于 config.yaml，用于敏感信息或部署覆盖
#
# AI Provider 配置规则：
#   - API Key:    {PROVIDER_NAME}_API_KEY
#   - Base URL:   {PROVIDER_NAME}_BASE_URL
#   - Model:      {PROVIDER_NAME}_MODEL
# 示例：若 config.yaml 中 provider 为 "zhipu"，则：
#   ZHIPU_API_KEY=your_key
#   ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   ZHIPU_MODEL=glm-4-flash
#
# 详细配置请参考 config.example.yaml

# ============================================================
# 邮件 SMTP 配置（必需）
# ============================================================
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_USER=your_email@example.com
# SMTP_PASS=your_email_auth_code
